# ZedIdeaArena Environment Variables
# Copy this file to .env and fill in your values

# Supabase (Backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (Frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PawaPay (payments)
PAWAPAY_API_KEY=your-pawapay-api-key
PAWAPAY_WEBHOOK_SECRET=your-pawapay-webhook-secret

# Resend (email)
RESEND_API_KEY=re_...

# OneSignal (push notifications)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_DOMAIN=zedideaarena.com
NEXT_PUBLIC_OPENROUTER_KEY=your-openrouter-key
