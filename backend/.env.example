PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PawaPay
PAWAPAY_API_KEY=your-pawapay-api-key
PAWAPAY_WEBHOOK_SECRET=your-pawapay-webhook-secret
PAWAPAY_CALLBACK_URL=https://api.zedideaarena.com/api/webhooks/pawapay
PAWAPAY_API_URL=https://api.pawapay.com/v1

# Frontend URL
FRONTEND_URL=http://localhost:3000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://zedideaarena.com,https://www.zedideaarena.com,https://hub.zedideaarena.com,https://login.zedideaarena.com,https://vote.zedideaarena.com,https://admin.zedideaarena.com

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@zedideaarena.com

# OneSignal (push notifications)
ONESIGNAL_APP_ID=...
ONESIGNAL_REST_API_KEY=...

# Default competition fees (in cents)
DEFAULT_ENTRY_FEE_CENTS=500
DEFAULT_VOTER_FEE_CENTS=0

# Ad viewer credit (cents per 3+ second impression)
AD_CREDIT_CENTS=1

# Stats display values (for public stats endpoint)
STATS_FUNDING_DISTRIBUTED=50000
STATS_COUNTRIES=12

# Redis (optional — for distributed rate limiting across multiple instances)
# If not set, rate limiter falls back to in-memory (single-process mode)
REDIS_URL=redis://default:password@host:port
